# Copy this file to `.env` in the repo root and fill in values.
# `.env` is gitignored — never commit real keys.

# Required for YouTube thumbnails, featured order, topic counts, and episode overlays.
# Restrict the key in Google Cloud Console (HTTP referrers) to your dev + production origins.
VITE_YOUTUBE_API_KEY=

# Optional: override RSS URL (e.g. same-origin proxy path if Anchor blocks CORS in production).
# VITE_PODCAST_RSS_URL=

# Optional (local dev only): enables Vite proxy for YouTube playlist Atom in vite.config.ts.
# VITE_YOUTUBE_PLAYLIST_ID=
